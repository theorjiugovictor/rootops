# ─── Custom Caddy with Duck DNS module ─────────────────────────
# Enables DNS-01 ACME challenge for automatic HTTPS via Duck DNS.
# Build: docker build -f Dockerfile.caddy -t rootops-caddy .

FROM caddy:builder AS builder

RUN xcaddy build \
    --with github.com/caddy-dns/duckdns

FROM caddy:latest
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
