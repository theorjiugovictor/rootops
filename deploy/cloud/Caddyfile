# ─── RootOps — Caddy Reverse Proxy ──────────────────────────────
# Routes traffic to the API (FastAPI) and Web (Next.js) services.
# Automatic HTTPS via Duck DNS DNS-01 challenge.
#
# Environment variables (set in docker-compose):
#   DOMAIN        — e.g. rootops.duckdns.org
#   DUCKDNS_TOKEN — your Duck DNS API token

{$DOMAIN} {

	# ── FastAPI backend ──────────────────────────────────────
	# API endpoints — route directly to FastAPI (skip Next.js hop)
	handle /api/* {
		reverse_proxy api:8000
	}

	# OpenTelemetry log receiver (OTLP/HTTP standard endpoint)
	handle /v1/* {
		reverse_proxy api:8000
	}

	# Health check
	handle /health {
		reverse_proxy api:8000
	}

	# Swagger / ReDoc documentation
	handle /docs {
		reverse_proxy api:8000
	}
	handle /docs/* {
		reverse_proxy api:8000
	}
	handle /openapi.json {
		reverse_proxy api:8000
	}
	handle /redoc {
		reverse_proxy api:8000
	}

	# ── Next.js frontend (everything else) ───────────────────
	handle {
		reverse_proxy web:3000
	}

	# ── TLS via Duck DNS ─────────────────────────────────────
	tls {
		dns duckdns {$DUCKDNS_TOKEN}
	}

	# ── Headers ──────────────────────────────────────────────
	header {
		# Security headers
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		# Remove server identifier
		-Server
	}

	# ── Logging ──────────────────────────────────────────────
	log {
		output stdout
		format console
		level INFO
	}
}
