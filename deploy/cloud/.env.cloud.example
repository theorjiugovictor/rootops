# ─── RootOps — Cloud Deployment Configuration ───────────────────
# Copy this to your project root .env (or merge with existing .env)
# before running: make cloud-deploy
#
# This file is for cloud (GCE + Caddy + Duck DNS) deployments only.
# For local Docker Compose, use .env.example instead.

# ═══════════════════════════════════════════════════════════════
# REQUIRED — Duck DNS
# ═══════════════════════════════════════════════════════════════
# 1. Go to https://www.duckdns.org and sign in (GitHub/Google/Reddit)
# 2. Create a subdomain → e.g. "rootops" gives you rootops.duckdns.org
# 3. Copy your token from the Duck DNS dashboard
DUCKDNS_SUBDOMAIN=rootops
DUCKDNS_TOKEN=your-duckdns-token-here

# ═══════════════════════════════════════════════════════════════
# REQUIRED — Google Cloud
# ═══════════════════════════════════════════════════════════════
GCP_PROJECT_ID=your-gcp-project-id
GCP_ZONE=us-central1-a

# VM size — pick based on your LLM backend:
#   e2-standard-4  (4 vCPU, 16 GB)  — for Ollama (local LLM, no API key)
#   e2-medium      (1 vCPU,  4 GB)  — for OpenAI / Anthropic / Bedrock
GCP_MACHINE_TYPE=e2-standard-4
GCP_DISK_SIZE=50
VM_NAME=rootops

# ═══════════════════════════════════════════════════════════════
# CLOUD PROVIDER & REMOTE ACCESS
# ═══════════════════════════════════════════════════════════════
# Used by `make cloud-*` targets. Set DEPLOY_HOST after first deploy.
# CLOUD_PROVIDER selects which deploy/teardown script to run.
CLOUD_PROVIDER=gcp
# DEPLOY_HOST=user@203.0.113.10     # set after VM is created (see deploy output)
# DEPLOY_DIR=/opt/rootops            # default, only change for custom installs
# DEPLOY_URL=https://rootops.duckdns.org  # your public URL for `make cloud-test`

# ═══════════════════════════════════════════════════════════════
# REQUIRED — LLM Backend
# ═══════════════════════════════════════════════════════════════
# Options: ollama, openai, anthropic, bedrock
#
# "ollama" is free but needs 16GB+ RAM and is slow without GPU.
# For cloud testing, OpenAI or Anthropic is recommended.
LLM_BACKEND=ollama
OLLAMA_MODEL=llama3

# ── OpenAI (uncomment to use) ──────────────────────────────────
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Anthropic (uncomment to use) ───────────────────────────────
# LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── AWS Bedrock (uncomment to use) ─────────────────────────────
# LLM_BACKEND=bedrock
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# BEDROCK_REGION=us-east-1

# ═══════════════════════════════════════════════════════════════
# OPTIONAL
# ═══════════════════════════════════════════════════════════════

# Database (bundled PostgreSQL — only change for external DB)
# POSTGRES_USER=rootops
# POSTGRES_PASSWORD=rootops
# POSTGRES_DB=rootops

# GitHub (for Auto-Heal PR creation)
# GITHUB_TOKEN=ghp_...
# GITHUB_DEFAULT_REPO=owner/repo

# Embeddings (defaults are fine for most users)
# EMBEDDING_MODEL_NAME=jinaai/jina-embeddings-v2-base-code
# EMBEDDING_DIMENSION=768

# Git repo to clone on the VM (defaults to the public GHCR repo)
# REPO_URL=https://github.com/theorjiugovictor/rootops-v3.git
