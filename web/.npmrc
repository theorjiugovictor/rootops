# ─── Supply Chain Hardening ───────────────────────────────────────
# All dependency installation happens inside Docker containers.
# These settings apply inside the container to further reduce risk.

# Block postinstall scripts — the #1 npm supply chain attack vector
# (e.g. event-stream, ua-parser-js, colors.js all used postinstall)
ignore-scripts=true

# Use exact versions, not ranges — prevents silent upgrades
save-exact=true

# Enforce lockfile — fail if package-lock.json is out of sync
# (prevents phantom dependency injection)
package-lock=true

# Run audit on every install
audit=true

# Stricter peer dependency resolution
strict-peer-deps=false

# Don't phone home
fund=false
update-notifier=false
