# ─── RootOps ──────────────────────────────────────────────────────
# Copy .env.example to .env and customize as needed.
# Only LLM_BACKEND needs to be set — everything else has sensible defaults.

# ── LLM Backend ──────────────────────────────────────────────────
# Which LLM to use. Options: ollama, openai, anthropic, bedrock
# Default: ollama (free, runs locally — no API key needed)
LLM_BACKEND=ollama

# ── Ollama (default — free, local) ──────────────────────────────
# Ollama runs as a Docker service automatically. Just pick a model.
# Popular choices: llama3, gemma3, mistral, qwen3, deepseek-r1
OLLAMA_MODEL=llama3

# ── OpenAI (optional) ──────────────────────────────────────────
# Set LLM_BACKEND=openai and provide your API key.
#
#   export OPENAI_API_KEY=sk-...          # one-time shell export
#
# Or set it permanently in this file:
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Anthropic (optional) ────────────────────────────────────────
# Set LLM_BACKEND=anthropic and provide your API key.
#
#   export ANTHROPIC_API_KEY=sk-ant-...   # one-time shell export
#
# Or set it permanently in this file:
# LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── AWS Bedrock (optional) ──────────────────────────────────────
# Set LLM_BACKEND=bedrock. Uses your local AWS credentials (~/.aws).
# No API key needed — IAM role or access key pair is picked up automatically.
#
#   export AWS_ACCESS_KEY_ID=...          # one-time shell export
#   export AWS_SECRET_ACCESS_KEY=...
#   export AWS_REGION=us-east-1
#
# Or set it permanently in this file:
# LLM_BACKEND=bedrock
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# BEDROCK_REGION=us-east-1

# ── Database ────────────────────────────────────────────────────
# PostgreSQL is bundled in Docker Compose. Change only if using external DB.
# POSTGRES_USER=rootops
# POSTGRES_PASSWORD=rootops
# POSTGRES_DB=rootops
# DB_PORT=5432

# ── Ports ───────────────────────────────────────────────────────
# API_PORT=8000
# WEB_PORT=3000
# OLLAMA_PORT=11434

# ── Embeddings ──────────────────────────────────────────────────
# Default: jinaai/jina-embeddings-v2-base-code (768-dim)
# Trained on code + English text — handles code chunks AND logs in one space.
# 8192-token context window. Runs locally, no API key needed.
#
# On first run the model (~600 MB) is downloaded automatically and cached
# in ~/.cache/huggingface on your host. Subsequent runs use the cache.
#
# IMPORTANT: If you change EMBEDDING_MODEL_NAME, you must:
#   1. Update EMBEDDING_DIMENSION to match the model's output size
#   2. Run: alembic upgrade head  (migration 0003 resizes the vector columns)
#   3. Re-ingest all repositories (old embeddings are dimension-incompatible)
#
# EMBEDDING_MODEL_NAME=jinaai/jina-embeddings-v2-base-code
# EMBEDDING_DIMENSION=768

# ── Intelligence features ────────────────────────────────────────
# HyDE: before embedding a query, ask the LLM to generate a hypothetical
# code answer, then embed THAT. Searching code-to-code beats question-to-code.
# HYDE_ENABLED=true

# Reranker: after vector retrieval, use a cross-encoder to re-score and
# re-order results. Much more precise than cosine similarity alone.
# RERANKER_ENABLED=true
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANKER_CANDIDATES=20   # candidates fetched before reranking to top_k

# Conversation memory: how many prior turns to include in each LLM call.
# CONVERSATION_HISTORY_TURNS=5

# ── RAG / Similarity Thresholds ────────────────────────────────
# Minimum cosine similarity (0.0–1.0) to include a result in query responses.
# Lower = more results but noisier. Higher = fewer but more precise.
# RAG_SIMILARITY_THRESHOLD=0.3
#
# Minimum similarity required for auto-heal to diagnose an error against code.
# Below this the LLM would hallucinate root causes rather than find real ones.
# HEAL_MIN_SIMILARITY=0.25

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# Defaults to the Next.js UI (localhost + Docker Compose service name).
# Set to * only for fully public, credential-free deployments.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://web:3000

# ── Remote Deployment (optional) ─────────────────────────────
# For managing RootOps on a remote VM via `make cloud-*` commands.
# Provision any Linux VM (GCP, AWS, DigitalOcean, Hetzner, etc.),
# then run: make cloud-deploy DEPLOY_HOST=user@ip
#
# DEPLOY_HOST=user@203.0.113.10
# DEPLOY_DIR=/opt/rootops
# DEPLOY_URL=https://rootops.example.com

# ── GitHub Integration (optional) ──────────────────────────────
# Required only for Auto-Heal PR creation feature
# GITHUB_TOKEN=ghp_...
# GITHUB_DEFAULT_REPO=owner/repo
